# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode/
.idea/

# Claude / Superpowers temp files
.claude/settings.local.json
.superpowers/brainstorm/*/state/
.playwright-mcp/

# OS
Thumbs.db

# ── Security-sensitive files ──
# Secrets, keys, and credentials
*.key
*.p12
*.pfx
*.jks
*.keystore
credentials.json
service-account*.json
secrets.json

# Lead data / PII
src/data/leads*.csv
src/data/leads*.json

# Admin auth
.admin-session

# Backup files that may contain secrets
*.bak
*.orig
*.swp
*.swo
