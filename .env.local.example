# Admin password for the /admin dashboard
ADMIN_PASSWORD=your-secure-password-here

# Secret for cache revalidation API endpoint
REVALIDATE_SECRET=your-revalidation-secret-here

# GitHub Personal Access Token (needs repo content read/write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repo info for CMS content management
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=calculator-app
GITHUB_BRANCH=main

# SendGrid API key for Excel template email delivery
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL database URL (Railway or other provider)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require